+    def forward(self, x: torch.Tensor, probe_path: str | None = None) -> torch.Tensor:
+        proj_in = self.net[0].proj(x)
+        act = torch.nn.functional.gelu(proj_in, approximate="tanh")
+        out_proj = self.net[2](act)
+        if probe_path and not os.path.exists(probe_path):
+            os.makedirs(os.path.dirname(probe_path), exist_ok=True)
+            torch.save(
+                {
+                    "ff_input": x.detach().to("cpu"),
+                    "proj_in": proj_in.detach().to("cpu"),
+                    "act": act.detach().to("cpu"),
+                    "out_proj": out_proj.detach().to("cpu"),
+                    "proj_in_weight": self.net[0].proj.weight.detach().to("cpu"),
+                    "proj_in_bias": self.net[0].proj.bias.detach().to("cpu"),
+                    "proj_out_weight": self.net[2].weight.detach().to("cpu"),
+                    "proj_out_bias": self.net[2].bias.detach().to("cpu"),
+                },
+                probe_path,
+            )
+        return out_proj
