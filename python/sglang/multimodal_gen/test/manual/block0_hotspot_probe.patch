+def _sglang_sublayer_probe_dump(name: str, block_idx: int, vx: torch.Tensor | None, ax: torch.Tensor | None) -> None:
+    """Dump block sub-layer output for sglang parity audit.
+
+    Enabled only when SGLANG_LTX_SUBLAYER_PROBE_DIR is set. Dumps only blocks listed in
+    SGLANG_LTX_SUBLAYER_PROBE_BLOCKS (comma-separated ints; default "0"). Each call gets
+    an index so multi-step / multi-pass runs don't clobber step 0. Filename is
+    `block{idx:02d}_{name}_call{n:03d}.pt`. Silent no-op otherwise.
+    """
+    probe_dir = os.environ.get("SGLANG_LTX_SUBLAYER_PROBE_DIR")
+    if not probe_dir:
+        return
+    blocks_env = os.environ.get("SGLANG_LTX_SUBLAYER_PROBE_BLOCKS", "0")
+    try:
+        allowed = {int(s) for s in blocks_env.split(",") if s.strip()}
+    except ValueError:
+        return
+    if block_idx not in allowed:
+        return
+    try:
+        max_calls = int(os.environ.get("SGLANG_LTX_SUBLAYER_PROBE_MAX_CALLS", "3"))
+    except ValueError:
+        max_calls = 3
+    call_key = (block_idx, name)
+    call_idx = _SGLANG_SUBLAYER_PROBE_CALL_COUNTS.get(call_key, 0)
+    if call_idx >= max_calls:
+        return
+    _SGLANG_SUBLAYER_PROBE_CALL_COUNTS[call_key] = call_idx + 1
+    os.makedirs(probe_dir, exist_ok=True)
+    payload: dict[str, torch.Tensor] = {}
+    if vx is not None:
+        payload["video"] = vx.detach().to("cpu")
+    if ax is not None:
+        payload["audio"] = ax.detach().to("cpu")
+    path = os.path.join(probe_dir, f"block{block_idx:02d}_{name}_call{call_idx:03d}.pt")
+    torch.save(payload, path)
+
+
+def _sglang_sublayer_probe_path(name: str, block_idx: int) -> str | None:
+    probe_dir = os.environ.get("SGLANG_LTX_SUBLAYER_PROBE_DIR")
+    if not probe_dir:
+        return None
+    blocks_env = os.environ.get("SGLANG_LTX_SUBLAYER_PROBE_BLOCKS", "0")
+    try:
+        allowed = {int(s) for s in blocks_env.split(",") if s.strip()}
+    except ValueError:
+        return None
+    if block_idx not in allowed:
+        return None
+    os.makedirs(probe_dir, exist_ok=True)
+    return os.path.join(probe_dir, f"block{block_idx:02d}_{name}.pt")
+
+
+def _sglang_probe_dump_payload(name: str, block_idx: int, payload: dict[str, torch.Tensor | None]) -> None:
+    path = _sglang_sublayer_probe_path(name, block_idx)
+    if not path or os.path.exists(path):
+        return
+    torch.save(
+        {
+            key: value.detach().to("cpu")
+            for key, value in payload.items()
+            if isinstance(value, torch.Tensor)
+        },
+        path,
+    )
+
