# Secrets and runtime data — never commit
.env
.env.local
.env.*.local
dashboard-data/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.venv/

# Node / Next.js
node_modules/
.next/
out/
build/
*.tsbuildinfo

# Editors / OS
.DS_Store
.idea/
.vscode/
*.swp

# Overrides — sglang root .gitignore has `**/lib/` (standard Python-project
# rule to exclude virtualenv lib dirs). That pattern unintentionally matches
# our frontend's web/lib/ TypeScript helpers, so re-include them here.
!web/lib/
!web/lib/**
