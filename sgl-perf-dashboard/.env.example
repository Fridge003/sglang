# MinIO / S3 — read-only credentials for the ingester
MINIO_ENDPOINT=https://minio.<your-minio-host>.nip.io
MINIO_ACCESS_KEY=<dashboard-ingester-reader access key>
MINIO_SECRET_KEY=<dashboard-ingester-reader secret key>
MINIO_BUCKET=sglang-ci-logs
MINIO_REGION=us-east-1

# GitHub — optional. Leave empty and enrichment will degrade gracefully
# (commit metadata stays null until a valid token is provided).
# When set, needs `repo:read` on sgl-project/sglang.
GITHUB_TOKEN=
GITHUB_REPO=sgl-project/sglang

# Anthropic — only needed for M3 AI summaries. Safe to leave empty.
ANTHROPIC_API_KEY=

# Storage
DB_PATH=/data/dashboard.db
RETENTION_DAYS=90

# Ingester cadence (seconds)
INGESTER_INTERVAL_SECONDS=300

# API
API_HOST=0.0.0.0
API_PORT=8000

# Web
NEXT_PUBLIC_API_URL=/api
